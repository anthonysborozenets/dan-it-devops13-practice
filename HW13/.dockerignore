# Віртуальне середовище Python — не потрібне в образі,
# бо pip install всередині контейнера встановить все сам
venv/
.venv/
env/

# Байт-код Python — генерується автоматично, не треба копіювати
__pycache__/
*.pyc
*.pyo
*.pyd

# Файли тестів та результатів — не потрібні для роботи API
test_requests.py
results.txt

# Git-репозиторій — не потрібен у production-образі
.git/
.gitignore

# Налаштування редакторів
.vscode/
*.json

# macOS-сміттєві файли
.DS_Store

# Конфіг віртуального середовища
pyvenv.cfg
