# ─────────────────────────────────────────────────────────────
# Базовий образ: офіційний Python 3.11 на Alpine Linux
# Alpine — дуже маленький дистрибутив (~5 МБ), тому фінальний
# образ буде компактним (~80-100 МБ замість ~1 ГБ на Ubuntu)
# ─────────────────────────────────────────────────────────────
FROM python:3.11-alpine

# ─────────────────────────────────────────────────────────────
# Встановлюємо робочу директорію всередині контейнера.
# Усі наступні команди (COPY, RUN, CMD) виконуються відносно неї.
# ─────────────────────────────────────────────────────────────
WORKDIR /app

# ─────────────────────────────────────────────────────────────
# Спочатку копіюємо ЛИШЕ requirements.txt і встановлюємо залежності.
# Це важливий трюк: Docker кешує кожен шар (layer).
# Якщо ми змінимо тільки app.py, шар з pip install НЕ буде
# перебудовуватись — Docker візьме його з кешу. Швидше!
# ─────────────────────────────────────────────────────────────
COPY requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir gunicorn

# ─────────────────────────────────────────────────────────────
# Копіюємо решту файлів проекту в робочу директорію контейнера.
# .dockerignore не дозволить потрапити сюди зайвим файлам.
# ─────────────────────────────────────────────────────────────
COPY app.py .
COPY students.csv .

# ─────────────────────────────────────────────────────────────
# Оголошуємо порт, на якому слухатиме застосунок.
# EXPOSE — лише документація; реальне відкриття порту робить
# команда docker run -p 8000:8000
# ─────────────────────────────────────────────────────────────
EXPOSE 8000

# ─────────────────────────────────────────────────────────────
# Команда запуску контейнера через Gunicorn:
#   --workers 2        — два робочих процеси (для продуктивності)
#   --bind 0.0.0.0:8000 — слухати на всіх інтерфейсах, порт 8000
#   app:app            — файл app.py, об'єкт Flask з назвою "app"
# ─────────────────────────────────────────────────────────────
CMD ["gunicorn", "--workers", "2", "--bind", "0.0.0.0:8000", "app:app"]
